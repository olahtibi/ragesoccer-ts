{
  "name": "ragesoccer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "assets:players": "node scripts/build-player-sprite-maps.mjs",
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "npm run typecheck:app && npm run typecheck:tests",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:run"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
